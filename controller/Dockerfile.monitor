FROM python:3.11-slim

# Docker CLI をインストールして monitor.py が docker コマンドを実行できるようにする
RUN apt-get update && apt-get install -y --no-install-recommends \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# 特権なしのプレーンな python 監視コンテナ (docker.sock マウント経由でホストと通信)
CMD ["python3", "/controller/monitor.py"]
